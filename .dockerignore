# Build artifacts — we rebuild inside the container
**/bin
**/obj

# Version control
**/.git
**/.gitignore
**/.gitattributes

# IDE / editor caches
**/.vs
**/.vscode
**/.idea
**/*.user

# OS junk
**/.DS_Store
**/Thumbs.db

# Docker files themselves — no value inside the image
Dockerfile
.dockerignore

# Tests aren't copied into the image; excluding them speeds up the build context upload
tests/

# Frontend ships via deploy-web.yml -> Static Web App, never into the API image.
# Excluding it keeps the build context small (esp. a local web/node_modules).
web/

# Local docs and notes
README.md
LICENSE
