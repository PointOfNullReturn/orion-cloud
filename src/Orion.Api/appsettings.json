{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": []
  },
  "Geocoding": {
    "BaseUrl": "https://geocoding-api.open-meteo.com/v1/"
  },
  "ReverseGeocoding": {
    "BaseUrl": "https://api.bigdatacloud.net/data/"
  },
  "Weather": {
    "CacheTtlSeconds": 300,
    "OpenMeteo": {
      "BaseUrl": "https://api.open-meteo.com/v1/"
    },
    "OpenWeather": {
      "BaseUrl": "https://api.openweathermap.org/data/2.5/",
      "ApiKey": ""
    },
    "RateLimit": {
      "PermitLimit": 10,
      "WindowSeconds": 60
    }
  }
}
